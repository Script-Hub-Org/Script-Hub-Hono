[Script]
Script.Hub = type=http-request, pattern=^https?:\/\/script\.hub, timeout=15, script-path=https://raw.githubusercontent.com/Script-Hub-Org/Script-Hub-Hono/main/assets/release/script/Script.Hub.js

[MITM]
hostname = %APPEND% script.hub