#!name=Script Hub: 重写 & 规则集转换
#!desc=http://script.hub
#!category=Tool
#!arguments=Notify:开启通知
#!arguments-desc=Notify:\nScriptHub通知设置, 可选 开启通知, 关闭通知, 跟随链接

[Script]
Script.Hub = type=http-request, pattern=^https?:\/\/script\.hub, timeout=300, argument=Notify={{{Notify}}}, script-path=https://raw.githubusercontent.com/Script-Hub-Org/Script-Hub/main/script-hub.js

[MITM]
hostname = %APPEND% script.hub