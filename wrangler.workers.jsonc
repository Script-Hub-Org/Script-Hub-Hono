{
  "name": "script-hub",
  "main": "backend/index.ts",
  "compatibility_date": "2025-11-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": { "directory": "assets" },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
