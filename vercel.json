{
  "version": 2,
  "builds": [
    {
      "src": "edge/vercel.ts",
      "use": "@vercel/node"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(?!assets$)(.*)",
      "dest": "edge/vercel.ts"
    }
  ]
}
